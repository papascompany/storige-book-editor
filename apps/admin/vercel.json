{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "cd ../.. && pnpm install --no-frozen-lockfile --filter @storige/admin... --ignore-scripts",
  "buildCommand": "cd ../.. && pnpm --filter @storige/types build && pnpm --filter @storige/admin build",
  "outputDirectory": "apps/admin/dist",
  "ignoreCommand": "git diff --quiet HEAD^ HEAD ./ ../../packages/types ../../packages/ui",
  "build": {
    "env": {
      "VITE_API_BASE_URL": "https://api.papascompany.co.kr/api"
    }
  }
}
