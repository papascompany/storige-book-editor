{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "cd ../.. && pnpm install --no-frozen-lockfile --filter @storige/editor... --ignore-scripts",
  "buildCommand": "cd ../.. && pnpm --filter @storige/types build && pnpm --filter @storige/canvas-core build && pnpm --filter @storige/editor build",
  "outputDirectory": "dist",
  "ignoreCommand": "git diff --quiet HEAD^ HEAD ./ ../../packages/types ../../packages/canvas-core ../../packages/ui",
  "build": {
    "env": {
      "VITE_API_BASE_URL": "https://api.papascompany.co.kr/api"
    }
  },
  "headers": [
    {
      "comment": "index.html은 절대 캐시 안 함 — 새 deploy 시 옛 chunk hash 참조로 'Importing a module script failed' 발생 방지. /index.html과 / 모두 매칭.",
      "source": "/(index\\.html)?",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    },
    {
      "comment": "/assets/* 의 hashed 파일은 immutable로 1년 캐시 (파일명에 hash가 박혀 있어 안전)",
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
