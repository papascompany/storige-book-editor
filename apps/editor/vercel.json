{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "cd ../.. && pnpm install --no-frozen-lockfile --filter @storige/editor... --ignore-scripts",
  "buildCommand": "cd ../.. && pnpm --filter @storige/types build && pnpm --filter @storige/canvas-core build && pnpm --filter @storige/editor build",
  "outputDirectory": "apps/editor/dist",
  "ignoreCommand": "git diff --quiet HEAD^ HEAD ./ ../../packages/types ../../packages/canvas-core ../../packages/ui",
  "build": {
    "env": {
      "VITE_API_BASE_URL": "https://api.papascompany.co.kr/api"
    }
  }
}
