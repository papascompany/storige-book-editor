# Application
NODE_ENV=development
PORT=4000
CORS_ORIGIN=*
MAX_BODY_SIZE=100mb

# Database
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_USER=root
DATABASE_PASSWORD=
DATABASE_NAME=storige

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Storage (shared with bookmoa)
STORAGE_PATH=./storage
STORAGE_MAX_FILE_SIZE=104857600
UPLOAD_PATH=./storage/uploads
THUMBNAIL_PATH=./storage/thumbnails
PROCESSED_PATH=./storage/processed

# 저장계층 백엔드 (2026-06-13 R2 보강). local(기본) | s3
#   s3 는 앱-프록시 PDF 경로(/files/upload(/external), /files/:id/download(/external))만 R2로 저장.
#   nginx 직접서빙 /storage/* (라이브러리/썸네일/워커outputs)는 항상 로컬(Phase 2).
STORAGE_DRIVER=local
# STORAGE_DRIVER=s3 일 때만 필요 (Cloudflare R2 권장 — egress 무료):
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true

# 보존정책 cron (FileRetentionService) — expires_at < now 파일 하드삭제
FILE_RETENTION_DRY_RUN=0
FILE_RETENTION_BATCH=200

# Worker
WORKER_QUEUE_NAME=storige-worker

# API Keys (comma-separated for multiple keys)
API_KEYS=bookmoa_dev_key_change_this

# Bookmoa DB Connection (read-only)
BOOKMOA_DB_HOST=localhost
BOOKMOA_DB_PORT=3306
BOOKMOA_DB_USER=bookmoa_readonly
BOOKMOA_DB_PASSWORD=
BOOKMOA_DB_NAME=bookmoa

# Webhook
BOOKMOA_WEBHOOK_URL=
WEBHOOK_SECRET=

# AI Configuration
# Enable/disable AI features (default: false)
AI_ENABLED=false

# Anthropic Claude API (for layout generation)
ANTHROPIC_API_KEY=
LLM_MODEL=claude-3-5-sonnet-20241022

# Replicate API (for FLUX image generation)
REPLICATE_API_TOKEN=
FLUX_USE_SCHNELL=false
