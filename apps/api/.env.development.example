# ─────────────────────────────────────────────────────────────────
# apps/api 로컬 개발용 env 예시 (보안 SCRT, 2026-06-13)
#
# 사용법: 이 파일을 .env.development 로 복사한 뒤 실값을 채운다.
#   cp apps/api/.env.development.example apps/api/.env.development
#
# ⚠️ .env.development 는 .gitignore 대상 — 절대 커밋 금지 (PUBLIC 레포).
#    실값은 로컬에만 보관. 운영(VPS)은 ~/storige/.env 를 사용한다.
# ─────────────────────────────────────────────────────────────────

# Application
NODE_ENV=development
API_PORT=4000
MAX_BODY_SIZE=100mb
CORS_ORIGIN=*

# Database (로컬 MariaDB/MySQL)
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_USER=root
DATABASE_PASSWORD=change-me-local-db-password
DATABASE_NAME=storige

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=change-me-min-32-chars-random-string-for-local-dev
JWT_EXPIRES_IN=7d

# Worker
WORKER_PORT=4001
MAX_RETRY_ATTEMPTS=3
GHOSTSCRIPT_PATH=/opt/homebrew/bin/gs

# Storage
STORAGE_PATH=./storage
STORAGE_BASE_URL=http://localhost:4000
STORAGE_MAX_FILE_SIZE=104857600
UPLOAD_PATH=./storage/uploads
THUMBNAIL_PATH=./storage/thumbnails
PROCESSED_PATH=./storage/processed

# Admin 시드 계정 (필수 — 기본 비번 폴백 제거됨)
# DB 에 admin 계정이 없을 때만 사용되며, 미설정 시 API 기동이 명시 에러로 실패한다.
ADMIN_EMAIL=admin@storige.com
ADMIN_PASSWORD=change-me-strong-local-admin-password

# API Keys (콤마 구분 복수 키 지원 — 부팅 시 sites 테이블로 시드됨)
API_KEYS=local_dev_key_change_this

# Bookmoa DB Connection (read-only, 선택 — 미설정 시 연동 비활성)
BOOKMOA_DB_HOST=
BOOKMOA_DB_PORT=3306
BOOKMOA_DB_USER=
BOOKMOA_DB_PASSWORD=
BOOKMOA_DB_NAME=

# Webhook
BOOKMOA_WEBHOOK_URL=
WEBHOOK_SECRET=
