# Vite/Tooling configs that get emitted by tsc -b runs
# (소스는 .ts 만 추적; .js/.d.ts 는 tsc 가 생성하므로 무시)
apps/*/vite.config.js
apps/*/vite.config.d.ts
apps/*/vite.embed.config.js
apps/*/vite.embed.config.d.ts

# DB init script 운영 백업 (별도 백업 위치에 보관, git 추적 X)
docker/mysql/init.sql.bak.*

# Agent 간 작업 지시 / 답변 임시 파일 — git 추적 X (회상/히스토리용 로컬 보관만)
# Claude <-> Codex 협업 흐름에서 사용. 파일은 삭제하지 않고 로컬에 남겨두되 커밋은 안 함.
.tmp_*.md

# Partner API v1 OpenAPI export 산출물 (pnpm --filter @storige/api openapi:partner — CI 아티팩트로 배포)
apps/api/openapi-partner.json
