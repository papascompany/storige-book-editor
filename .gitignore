# Production builds
dist/
dist-embed/
build/
.next/

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# 시크릿 파일 커밋 금지 (보안 SCRT, 2026-06-13 — PUBLIC 레포)
# api/worker 런타임 env 는 VPS ~/storige/.env(untracked, chmod 600)에서 주입.
# 레포에는 *.example(플레이스홀더)만 커밋한다.
.env.production
.env.development
!.env*.example
!.env.development.example
!.env.production.example
# admin/editor 의 .env.production / .env.development 은 시크릿 없는
# 공개 Vite 설정(URL/플래그)이라 추적 유지.
!apps/admin/.env.production
!apps/admin/.env.development
!apps/editor/.env.production
.env*.bak*
계정정보*.html
*.secret.*
*.secrets.*
# 시크릿 회전 산출물 (2026-06-15~) — 백업 env/신구 시크릿 스테이징/회전 스크립트 절대 커밋 금지
.env.pre-rotation-*
.rotated-secrets-*
rotate_phase*.sh
rotate_verify_*.sh
# 시크릿 참조 핸드오프(키 스왑/회전/외부 DB 자격) — API 키 포함, PUBLIC 레포 커밋 금지
.cursor/plans/*KEY_SWAP*
.cursor/plans/*SECRET_ROTATION*
.cursor/plans/*DB_ROTATION*

# 내부 전용 분석 산출물 — PUBLIC 레포 커밋 금지
.cursor/plans/*EDITOR_BENCH*

# Claude Code local memory (operational secrets — SSH/VPS/API keys)
# 세션 간 자동 로드되는 로컬 메모리 — 절대 커밋 금지
CLAUDE.local.md
.claude/CLAUDE.local.md

