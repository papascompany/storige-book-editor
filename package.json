{
  "name": "storige",
  "version": "1.0.0",
  "private": true,
  "description": "Print Shopping Mall Worker & Editor System",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "golden:compare": "node scripts/pdf-golden/compare.mjs",
    "golden:test": "node --test scripts/pdf-golden/compare.test.mjs",
    "check:exposure": "node scripts/check-source-exposure.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.1.0",
    "prettier": "^3.3.3",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "pnpm": {
    "ignoredOptionalDependencies": [
      "canvas"
    ],
    "overrides": {
      "multer": "^2.2.0",
      "protobufjs": "^7.5.5",
      "path-to-regexp@0.1.x": "~0.1.13"
    }
  }
}
