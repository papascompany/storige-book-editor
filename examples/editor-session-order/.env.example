# examples/editor-session-order — 환경변수 견본
#
#   cp .env.example .env && node --env-file=.env src/server.ts
#
# ⚠️ `.env` 는 커밋하지 않는다(레포 .gitignore 가 이미 막고 있다).

# ── 🔒 서버 전용 (브라우저로 절대 내려가지 않는다) ──────────────────────
# 파트너 API 키. 이 값이 프런트로 새면 그 키를 얻은 누구나 테넌트 전체를 조작한다.
STORIGE_API_KEY=

# Partner API 오리진(경로 접두 /api/v1 은 SDK 가 붙인다).
STORIGE_BASE_URL=https://api.example.com

# ── 브라우저에 내려가는 공개 값 ─────────────────────────────────────────
# 편집기 배포 오리진. iframe src 와 postMessage 화이트리스트가 여기서 나온다.
STORIGE_EDITOR_URL=https://editor.example.com

# 편집할 템플릿셋 id (신규 편집 필수).
STORIGE_TEMPLATE_SET_ID=

# 편집기에 넘길 회원 세션 토큰(JWT).
# ⚠️ 비우면 게스트 세션이 된다 → 세션에 소유 사이트가 없어 승격이 404 로 거부된다.
STORIGE_EDITOR_TOKEN=

# 파트너 주문번호(선택) — 편집기가 세션 메타로 보관하고 completed payload 에 echo 한다.
STORIGE_ORDER_SEQNO=

# 초기 페이지 수(선택).
STORIGE_PAGE_COUNT=

# 재편집(선택) — 기존 세션을 다시 연다. templateSetId 는 세션에서 도출된다.
STORIGE_SESSION_ID=

# ── 호스트 서버 ─────────────────────────────────────────────────────────
PORT=4001

# 이 호스트 페이지의 오리진. 편집기 `parentOrigin` 파라미터로 그대로 들어가고,
# 편집기는 이 오리진으로만 postMessage 를 보낸다('*' 를 쓰지 않는다).
# ⚠️ 편집기 CSP frame-ancestors 에 등록된 도메인이어야 iframe 이 뜬다.
HOST_ORIGIN=http://localhost:4001
