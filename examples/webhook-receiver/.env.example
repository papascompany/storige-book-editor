# examples/webhook-receiver — 환경변수 견본
#
#   cp .env.example .env && node --env-file=.env src/server.ts
#
# ⚠️ `.env` 는 커밋하지 않는다(레포 .gitignore 가 이미 막고 있다).

# ── 필수 ────────────────────────────────────────────────────────────────
# 🔒 서명 secret.
#   v2(사이트별 opt-in): 웹훅 config 생성/회전 응답에 **1회만** 노출되는 whsec_...
#                        재조회 불가 — 받은 즉시 안전한 저장소에 보관하라.
#   v1(레거시 전역)    : 서버 WEBHOOK_SECRET 과 공유한 값.
#
# 미설정이면 프로세스가 **뜨지 않는다**(의도된 동작 — 오설정은 배포에서 터져야 한다).
# ⚠️ 코드에서 `process.env.STORIGE_WEBHOOK_SECRET!` 로 우회하지 마라. `!` 는 타입만
#    속일 뿐 런타임 undefined 를 막지 못한다.
STORIGE_WEBHOOK_SECRET=

# ── 선택 ────────────────────────────────────────────────────────────────
# replay 허용 창(초). 헤더 `t`(서명 시각) 기준이며 payload.timestamp 가 아니다.
# 좁힐수록 캡처된 서명의 재생 가능 시간이 준다. NaN 이 되면 검사가 통째로 꺼지므로
# 값을 비우거나 숫자만 넣어라(비숫자는 기동 실패).
STORIGE_WEBHOOK_TOLERANCE_SEC=300

# 수신 경로 — 웹훅 config 에 등록한 URL 의 경로와 맞춰라.
STORIGE_WEBHOOK_PATH=/webhooks/storige

PORT=4002

# 본문을 믿지 않고 서버에 되묻기 위한 파트너 키(둘을 함께 설정하거나 함께 비운다).
# 운영에서는 **반드시 설정하라** — 서명은 본문을 덮지 않으므로 부수효과의 근거는
# 재조회에서 취해야 한다.
STORIGE_API_KEY=
STORIGE_BASE_URL=
