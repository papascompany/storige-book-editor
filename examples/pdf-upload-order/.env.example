# examples/pdf-upload-order — 환경변수 견본
#
# 이 파일을 `.env` 로 복사한 뒤 값을 채우고 실행한다.
#   cp .env.example .env && node --env-file=.env src/main.ts
#
# ⚠️ `.env` 는 커밋하지 않는다(레포 .gitignore 가 이미 막고 있다).

# ── 필수 ────────────────────────────────────────────────────────────────
# 파트너 API 키. env(test/live)는 키에 내재한다 — 코드 파라미터가 아니다.
# test 키로 시작하라: 데이터가 live 와 완전히 격리된다.
STORIGE_API_KEY=

# 서버 오리진. 경로 접두 `/api/v1` 은 SDK 가 붙이므로 넣지 않는다.
STORIGE_BASE_URL=https://api.example.com

# ── 자산(둘 중 한 경로) ─────────────────────────────────────────────────
# ① 권장 — 동결 업로드 표면(presigned ≤2GB)에 먼저 올려서 받은 files.id.
#    본문이 JSON 이라 SDK 가 Idempotency-Key 를 자동 부여한다.
STORIGE_COVER_FILE_ID=
STORIGE_CONTENTS_FILE_ID=

# ② 직접 업로드(멀티파트 ≤100MB, PDF 만) — 로컬 PDF 경로.
#    fileId 가 비어 있을 때만 사용된다. 멱등 주의사항은 README 참조.
STORIGE_COVER_PDF_PATH=
STORIGE_CONTENTS_PDF_PATH=

# ── 주문 파라미터 ───────────────────────────────────────────────────────
# 판형 uid(bs_...). 비우면 활성 판형 목록의 첫 항목을 골라 쓴다(데모용).
STORIGE_BOOK_SPEC_UID=

# 내지 페이지 수. 판형의 pageMin/pageMax/pageIncrement 를 지켜야 한다.
STORIGE_PAGE_COUNT=24

# 파트너측 자체 주문 참조(자유 문자열) — 나중에 도서를 되찾을 때 쓴다.
STORIGE_PARTNER_REF=demo-order-0001

# 최종 PDF 를 저장할 경로.
STORIGE_OUTPUT_PDF_PATH=./out/final.pdf

# 폴링 대신 웹훅을 쓰려면 1 로 둔다(폴링을 건너뛰고 최종화 착수까지만 수행).
# 웹훅 수신 서버는 examples/webhook-receiver 참조.
STORIGE_SKIP_POLLING=0
