    {
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 14, "w": 24, "x": 0, "y": 1 },
      "id": 201,
      "title": "API 로그 (level filter: $level)",
      "type": "logs",
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "expr": "{service=\"api\"} | json | level=~\"$level\"",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 14, "w": 24, "x": 0, "y": 15 },
      "id": 202,
      "title": "Worker 로그 (level filter: $level)",
      "type": "logs",
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "expr": "{service=\"worker\"} | json | level=~\"$level\"",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "📊 로그 메트릭",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 29 },
      "id": 203,
      "panels": []
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 30 },
      "id": 204,
      "title": "에러 발생률 (errors/min, 서비스별)",
      "type": "timeseries",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "red" },
          "unit": "cpm"
        }
      },
      "targets": [
        {
          "expr": "sum by (service) (rate({service=~\"api|worker\"} | json | level=\"error\" [1m]))",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 30 },
      "id": 205,
      "title": "전체 로그 처리량 (lines/sec)",
      "type": "timeseries",
      "fieldConfig": { "defaults": { "unit": "logs" } },
      "targets": [
        {
          "expr": "sum by (service) (rate({service=~\"api|worker|nginx\"}[1m]))",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "🌐 Nginx 액세스 로그",
      "collapsed": true,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 38 },
